# CirrusLabs GTM System - Environment Variables

# ============================================================================
# DATABASE (Supabase)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co

# Anon key (public, read-heavy operations)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (bypasses RLS — required for CLI skills)
# Found in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Postgres connection string (for migrations)
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Frontend/Dashboard — required for Next.js dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# PRIMARY PLATFORM - Apollo.io
# Covers: company search, contact discovery, sequences, analytics
# Sign up: https://app.apollo.io
# API key: Settings → Integrations → API
# ============================================================================
APOLLO_API_KEY=

# ============================================================================
# AI COPY GENERATION
# ============================================================================

# OpenAI - Email + LinkedIn copy generation (Skill 3)
# Sign up: https://platform.openai.com
OPENAI_API_KEY=

# ============================================================================
# OPTIONAL ENRICHMENT (future use)
# ============================================================================

# Exa - AI web search for news/funding signals
# EXA_API_KEY=

# Perplexity - Research API
# PERPLEXITY_API_KEY=

# ============================================================================
# OPTIONAL — Rate limiting (Upstash Redis). If absent, rate limiting is skipped.
# Sign up: https://upstash.com — create a Redis database, copy REST URL + token
# ============================================================================

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# SYSTEM
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info
