    "test": "echo 'No tests yet. Run skills to test functionality.'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "axios": "^1.10.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "googleapis": "^171.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.1",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@10.2.0"
