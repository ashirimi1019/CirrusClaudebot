{
  "name": "career-source-group-agent",
  "version": "0.1.0",
  "description": "Agentic AI system for signal-driven staffing outreach",
  "type": "module",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "skill:1": "node --loader ts-node/esm scripts/run-skill-1-new-offer.ts",
    "skill:2": "node --loader ts-node/esm scripts/run-skill-2-campaign-strategy.ts",
    "skill:3": "node --loader ts-node/esm scripts/run-skill-3-campaign-copy.ts",
    "skill:4": "node --loader ts-node/esm scripts/run-skill-4-find-leads.ts",
    "skill:5": "node --loader ts-node/esm scripts/run-skill-5-launch-outreach.ts",
    "skill:6": "node --loader ts-node/esm scripts/run-skill-6-campaign-review.ts",
    "pipeline": "node --loader ts-node/esm scripts/run-pipeline.ts",
    "sheets:sync": "node --loader ts-node/esm scripts/run-sheets-sync.ts",
    "brain": "node --loader ts-node/esm scripts/run-brain.ts",
    "skill:ingest": "node --loader ts-node/esm scripts/run-reply-ingestion.ts",
